# =============================================================================
# ClearMarine — env template (copy to .env at repo root)
# =============================================================================
# This single file can hold BOTH frontend and backend keys.
#
# Required for app startup:
#   - REACT_APP_SUPABASE_URL
#   - REACT_APP_SUPABASE_ANON_KEY
#
# Required for AI features in the React app:
#   - REACT_APP_GEMINI_API_KEY
#
# Required for backend voice STT/TTS endpoints:
#   - ELEVENLABS_KEY
# =============================================================================

REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for AI features in the React app
REACT_APP_GEMINI_API_KEY=your-gemini-api-key

# Optional Gemini text model (default gemini-2.5-flash)
# REACT_APP_GEMINI_TEXT_MODEL=gemini-2.5-flash

# Optional — voice report → form dropdown mapping model
# REACT_APP_GEMINI_VOICE_INFER_MODEL=gemini-1.5-pro

# Backend URL for /transcribe + /tts.
# - Local split setup: http://localhost:8787
# - Single Vercel app: leave blank to use same-origin /api
# REACT_APP_BACKEND_URL=http://localhost:8787

# Optional demo speed scaling for maintenance timers
# REACT_APP_MAINTENANCE_SCALE=0.05

# Optional: Roboflow routes (off unless REACT_APP_ENABLE_ROBOFLOW=1)
# REACT_APP_ENABLE_ROBOFLOW=1
# REACT_APP_ROBOFLOW_DETECT_URL=https://detect.roboflow.com/your-workspace/your-project/1
# REACT_APP_ROBOFLOW_API_KEY=
# REACT_APP_ROBOFLOW_PROXY_URL=http://localhost:8787

# Optional: local YOLO server (better recall than in-browser COCO-SSD on some photos)
# REACT_APP_CV_SERVER_URL=http://127.0.0.1:8765

# Optional: resupply lead-time scaling
# REACT_APP_SUPPLY_LEAD_SCALE=1

# -------------------------------
# Backend keys (same file)
# -------------------------------
# Optional for local standalone backend only
PORT=8787

# Required for /api/transcribe and /api/tts
ELEVENLABS_KEY=

# Optional backend tuning
# ELEVENLABS_STT_MODEL=scribe_v2
# ELEVENLABS_STT_LANGUAGE=en
# ELEVENLABS_VOICE_ID=21m00TcmT4DvrzdWaoCl6
# ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
