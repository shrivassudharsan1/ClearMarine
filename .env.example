# =============================================================================
# ClearMarine — env template (copy to .env at repo root)
# =============================================================================
#
# Active now (browser + this file):
#   • Groq — debris reconciliation, impact/responder pass, crew / handoff text
#     https://console.groq.com
#   • ElevenLabs speech-to-text — NOT here; configure the backend instead
#     (see backend/.env.example → ELEVENLABS_KEY). Voice uses REACT_APP_BACKEND_URL.
#
# Planned later (dependencies may already be in package.json; code paths off by default):
#   • Google Gemini — photo vision / extra LLM passes (re-enable in src/lib/gemini.js when ready)
#   • Roboflow — optional CV; enable with REACT_APP_ENABLE_ROBOFLOW=1 plus URLs/keys below
#
# =============================================================================

REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for AI features in the React app
REACT_APP_GROQ_API_KEY=your-groq-api-key

# Optional Groq text model (default llama-3.1-8b-instant)
# REACT_APP_GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Optional — voice report → form dropdown mapping (defaults to a 70B-capable chain in code)
# REACT_APP_GROQ_VOICE_INFER_MODEL=llama-3.3-70b-versatile

# Backend URL for /transcribe (ElevenLabs STT). Example: http://localhost:8787
# REACT_APP_BACKEND_URL=http://localhost:8787

# --- Future: Gemini (commented until wired back in) ---
# REACT_APP_GEMINI_API_KEY=
# REACT_APP_GEMINI_VISION_MODEL=gemini-2.0-flash

# --- Future: Roboflow (off unless REACT_APP_ENABLE_ROBOFLOW=1) ---
# REACT_APP_ENABLE_ROBOFLOW=1
# REACT_APP_ROBOFLOW_DETECT_URL=https://detect.roboflow.com/your-workspace/your-project/1
# REACT_APP_ROBOFLOW_API_KEY=
# REACT_APP_ROBOFLOW_PROXY_URL=http://localhost:8787

# Optional: local YOLO server (better recall than in-browser COCO-SSD on some photos)
# REACT_APP_CV_SERVER_URL=http://127.0.0.1:8765
