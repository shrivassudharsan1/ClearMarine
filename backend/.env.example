# Copy to backend/.env (never commit real secrets)
#
# Required:
#   - ELEVENLABS_KEY (used by POST /transcribe and POST /tts)
#
# Optional:
#   - PORT (default 8787)
#   - ELEVENLABS_STT_MODEL (default scribe_v2)
#   - ELEVENLABS_STT_LANGUAGE (language hint)
#   - ELEVENLABS_VOICE_ID (default Rachel voice)
#   - ELEVENLABS_TTS_MODEL (default eleven_multilingual_v2)
#   - ROBOFLOW_API_KEY (for /detect proxy route)

PORT=8787
ELEVENLABS_KEY=
# Optional — defaults to scribe_v2
ELEVENLABS_STT_MODEL=scribe_v2
# Optional — language hint for Scribe (e.g. en). Omit if your API version ignores it.
# ELEVENLABS_STT_LANGUAGE=en
# Optional — default is premade Rachel voice
# ELEVENLABS_VOICE_ID=21m00TcmT4DvrzdWaoCl6
# Optional — default is eleven_multilingual_v2
# ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# Optional — Roboflow proxy (used by /detect)
ROBOFLOW_API_KEY=
