# Copy to backend/.env (never commit real secrets)
#
# Active now:
#   ELEVENLABS_KEY — POST /transcribe (Scribe STT) + POST /tts (spoken clarification)
#   Optional: ELEVENLABS_VOICE_ID (default premade Rachel), ELEVENLABS_TTS_MODEL (default eleven_turbo_v2_5)
#
# Planned later:
#   ROBOFLOW_API_KEY — proxy route for browser Roboflow calls when you re-enable CV

PORT=8787
ELEVENLABS_KEY=
# Optional — defaults to scribe_v2
ELEVENLABS_STT_MODEL=scribe_v2
# Optional — language hint for Scribe (e.g. en). Omit if your API version ignores it.
# ELEVENLABS_STT_LANGUAGE=en

# Future — Roboflow proxy (leave blank until implemented)
ROBOFLOW_API_KEY=
